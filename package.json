{
  "name": "amelie-la-vie",
  "private": true,
  "version": "2.0.0",
  "description": "Amélie la Vie — site associatif (Astro + Sanity)",
  "author": "Victor Giroud",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --write .",
    "studio:dev": "pnpm --filter studio dev",
    "studio:build": "pnpm --filter studio build",
    "studio:deploy": "pnpm --filter studio deploy",
    "migrate:content": "node scripts/migrate-md-to-sanity.mjs",
    "migrate:partenaires": "node scripts/import-partenaires.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.2.1",
    "@fontsource-variable/lora": "^5.1.1",
    "@portabletext/to-html": "^2.0.14",
    "@sanity/client": "^7.12.0",
    "@sanity/image-url": "^1.1.0",
    "@sanity/visual-editing": "^2.15.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.3",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.9"
  }
}
