    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 22v-8h2.7l.4-3.2h-3.1V8.7c0-.9.3-1.6 1.6-1.6h1.6V4.3c-.3 0-1.2-.1-2.3-.1-2.3 0-3.9 1.4-3.9 4v2.6H8v3.2h2.5V22h3z"/></svg>',
  youtube:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.6 7.2c-.2-.9-.9-1.6-1.8-1.8C18.2 5 12 5 12 5s-6.2 0-7.8.4c-.9.2-1.6.9-1.8 1.8C2 8.8 2 12 2 12s0 3.2.4 4.8c.2.9.9 1.6 1.8 1.8 1.6.4 7.8.4 7.8.4s6.2 0 7.8-.4c.9-.2 1.6-.9 1.8-1.8.4-1.6.4-4.8.4-4.8s0-3.2-.4-4.8zM10 15V9l5 3-5 3z"/></svg>',
  instagram:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2 0 1.8.3 2.2.5.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .5 2.2 0 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c0 1.2-.3 1.8-.5 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.5-1.3 0-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2 0-1.8-.3-2.2-.5-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.4-1-.5-2.2 0-1.3-.1-1.7-.1-4.9s0-3.6.1-4.9c0-1.2.3-1.8.5-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.5C8.4 2.2 8.8 2.2 12 2.2zM12 0C8.7 0 8.3 0 7.1.1 5.8.1 5 .3 4.2.6c-.8.3-1.5.7-2.2 1.4-.7.7-1.1 1.4-1.4 2.2-.3.8-.5 1.6-.6 2.9C0 8.3 0 8.7 0 12s0 3.7.1 4.9c.1 1.3.3 2.1.6 2.9.3.8.7 1.5 1.4 2.2.7.7 1.4 1.1 2.2 1.4.8.3 1.6.5 2.9.6C8.3 24 8.7 24 12 24s3.7 0 4.9-.1c1.3-.1 2.1-.3 2.9-.6.8-.3 1.5-.7 2.2-1.4.7-.7 1.1-1.4 1.4-2.2.3-.8.5-1.6.6-2.9 0-1.2.1-1.6.1-4.9s0-3.7-.1-4.9c-.1-1.3-.3-2.1-.6-2.9-.3-.8-.7-1.5-1.4-2.2-.7-.7-1.4-1.1-2.2-1.4-.8-.3-1.6-.5-2.9-.6C15.7 0 15.3 0 12 0zm0 5.8C8.6 5.8 5.8 8.6 5.8 12s2.8 6.2 6.2 6.2 6.2-2.8 6.2-6.2-2.8-6.2-6.2-6.2zm0 10.2c-2.2 0-4-1.8-4-4s1.8-4 4-4 4 1.8 4 4-1.8 4-4 4zm6.4-11.8c-.8 0-1.4.6-1.4 1.4s.6 1.4 1.4 1.4 1.4-.6 1.4-1.4-.6-1.4-1.4-1.4z"/></svg>',
  linkedin:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3H5C3.9 3 3 3.9 3 5v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM8.5 18H5.8V9.8h2.7V18zM7.1 8.6C6.3 8.6 5.6 8 5.6 7.1c0-.8.7-1.4 1.5-1.4s1.5.6 1.5 1.4c0 .9-.7 1.5-1.5 1.5zM18.2 18h-2.7v-4c0-1 0-2.3-1.4-2.3-1.4 0-1.6 1.1-1.6 2.2V18H9.8V9.8h2.6v1.1h.1c.4-.7 1.2-1.4 2.5-1.4 2.7 0 3.2 1.8 3.2 4V18z"/></svg>',
  x: '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
};
---

<footer class="bg-ink text-paper mt-20">
  <Container width="screen" class="py-14 sm:py-20">
    <div class="grid gap-10 md:grid-cols-12">
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center gap-3" aria-label="Accueil">
          {
            siteSettings?.logo ? (
              <SanityImage
                image={siteSettings.logo}
                width={240}
                sizes="240px"
                loading="lazy"
                transparent
                class="h-12 w-auto"
                alt={siteSettings.title}
              />
            ) : (
              <span class="text-xl font-semibold">{siteSettings?.title ?? "Amélie la Vie"}</span>
            )
          }
        </a>
        {
          siteSettings?.shortDescription && (
            <p class="text-paper/70 mt-4 max-w-sm text-sm">{siteSettings.shortDescription}</p>
          )
        }
        {
          navigation?.social && navigation.social.length > 0 && (
            <ul class="mt-6 flex items-center gap-2">
              {navigation.social.map((s) => (
                <li>
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={s.label}
                    class="text-paper/70 hover:text-paper inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-white/20"
                  >
                    {/* eslint-disable-next-line astro/no-set-html-directive */}
                    <span class="block h-5 w-5" set:html={socialIcons[s.platform] ?? ""} />
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>

      {
        navigation?.footerColumns?.map((col) => (
          <nav class="md:col-span-3" aria-label={col.heading}>
            <h2 class="text-paper text-sm font-semibold tracking-wider uppercase">{col.heading}</h2>
            <ul class="mt-4 space-y-2 text-sm">
              {col.links?.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-paper/80 hover:text-paper hover:underline"
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }

      <div class="md:col-span-2">
        <h2 class="text-paper text-sm font-semibold tracking-wider uppercase">Contact</h2>
        <ul class="mt-4 space-y-2 text-sm">
          {
            contactInfo?.email && (
              <li>
                <a
                  href={`mailto:${contactInfo.email}`}
                  class="text-paper/80 hover:text-paper hover:underline"
                >
                  {contactInfo.email}
                </a>
              </li>
            )
          }
          {
            contactInfo?.phone && (
              <li>
                <a
                  href={`tel:${contactInfo.phone.replace(/\s/g, "")}`}
                  class="text-paper/80 hover:text-paper hover:underline"
                >
                  {contactInfo.phone}
                </a>
              </li>
            )
          }
          {contactInfo?.address && <li class="text-paper/80 text-sm">{contactInfo.address}</li>}
        </ul>
      </div>
    </div>

    <div
      class="border-paper/10 mt-12 flex flex-col items-center justify-between gap-4 border-t pt-6 text-xs sm:flex-row"
    >
      <p class="text-paper/60">
        © {year}
        {siteSettings?.title ?? "Amélie la Vie"}.
        {navigation?.footerLegalNote}
      </p>
      <p class="text-paper/70">
        <a href="https://amelielavie.sanity.studio" class="hover:text-paper">Admin</a>
      </p>
    </div>
  </Container>
</footer>
