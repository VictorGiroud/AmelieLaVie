---
import Container from "@components/ui/Container.astro";
import Button from "@components/ui/Button.astro";
import SanityImage from "@components/ui/Image.astro";
import type { SectionHero } from "@lib/sanity/types";

interface Props {
  section: SectionHero;
  /** Index dans la page (le premier hero = LCP). */
  index?: number;
}

const { section, index = 0 } = Astro.props;
const isFirst = index === 0;
const isQuote = section.displayStyle === "quote";
---

<section class="relative overflow-hidden">
  {
    section.backgroundImage?.asset && (
      <div class="absolute inset-0 -z-10">
        <SanityImage
          image={section.backgroundImage}
          width={1920}
          sizes="100vw"
          loading={isFirst ? "eager" : "lazy"}
          class="h-full w-full object-cover"
          decorative={!section.backgroundImage.alt}
        />
        <div class="bg-paper/70 absolute inset-0" aria-hidden="true" />
      </div>
    )
  }
  <Container width="screen" class={isQuote ? "py-6 sm:py-10 text-center" : "py-10 sm:py-14"}>
    {
      section.alerte && (
        <p
          class={`bg-brand-100 text-brand-800 mb-5 inline-flex rounded-full px-4 py-1.5 text-sm font-medium ${isQuote ? "" : ""}`}
        >
          {section.alerte}
        </p>
      )
    }
    {
      isQuote ? (
        <h1 class="hero-quote text-ink mx-auto max-w-3xl font-serif text-3xl leading-snug italic sm:text-4xl">
          {section.title}
        </h1>
      ) : (
        <h1 class="max-w-3xl text-3xl font-semibold sm:text-4xl">{section.title}</h1>
      )
    }
    {
      section.subtitle && (
        <p
          class={`text-ink-muted mt-3 text-base sm:text-lg ${isQuote ? "mx-auto max-w-2xl" : "max-w-2xl"}`}
        >
          {section.subtitle}
        </p>
      )
    }
    {
      section.ctas && section.ctas.length > 0 && (
        <div class={`mt-6 flex flex-wrap gap-3 ${isQuote ? "justify-center" : ""}`}>
          {section.ctas.map((cta) => (
            <Button cta={cta} size="lg" />
          ))}
        </div>
      )
    }
  </Container>
</section>

<style>
  /* Guillemets typographiques français (style citation) */
  .hero-quote::before {
    content: "«\00a0";
    font-style: normal;
    color: var(--color-brand-500);
    opacity: 0.7;
  }
  .hero-quote::after {
    content: "\00a0»";
    font-style: normal;
    color: var(--color-brand-500);
    opacity: 0.7;
  }
</style>
