---
import Section from "@components/ui/Section.astro";
import SanityImage from "@components/ui/Image.astro";
import Button from "@components/ui/Button.astro";
import type { SectionBlurbs } from "@lib/sanity/types";

interface Props {
  section: SectionBlurbs;
}

const { section } = Astro.props;
const cols = Math.min(section.items.length, 3);
const colClass = cols >= 3 ? "md:grid-cols-3" : cols === 2 ? "md:grid-cols-2" : "max-w-xl mx-auto";
---

<Section background="alt" width="wide">
  {
    section.heading && (
      <h2 class="mb-10 text-center text-3xl font-semibold sm:text-4xl">{section.heading}</h2>
    )
  }
  <ul class={`grid gap-8 ${colClass}`}>
    {
      section.items.map((item) => (
        <li class="bg-paper border-border flex flex-col rounded-lg border p-6">
          {item.image?.asset && (
            <SanityImage
              image={item.image}
              width={400}
              sizes="(min-width: 768px) 33vw, 100vw"
              class="aspect-video w-full rounded object-cover"
            />
          )}
          {item.title && <h3 class="mt-4 text-xl font-semibold">{item.title}</h3>}
          {item.text && (
            <p class="text-ink-muted mt-3 flex-1 text-sm leading-relaxed">{item.text}</p>
          )}
          {item.link && (
            <div class="mt-5">
              <Button cta={item.link} variant="ghost" />
            </div>
          )}
        </li>
      ))
    }
  </ul>
</Section>
