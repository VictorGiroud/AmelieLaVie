---
import Section from "@components/ui/Section.astro";
import SanityImage from "@components/ui/Image.astro";
import type { SectionGallery } from "@lib/sanity/types";

interface Props {
  section: SectionGallery;
}

const { section } = Astro.props;
---

<Section background="white" width="wide">
  {section.title && <h2 class="mb-8 text-3xl font-semibold sm:text-4xl">{section.title}</h2>}
  <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
    {
      section.images.map((img) => (
        <li>
          <figure>
            <SanityImage
              image={img}
              width={600}
              sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
              class="aspect-square w-full rounded object-cover"
            />
            {img.caption && (
              <figcaption class="text-ink-muted mt-2 text-xs">{img.caption}</figcaption>
            )}
          </figure>
        </li>
      ))
    }
  </ul>
</Section>
