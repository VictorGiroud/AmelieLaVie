---
import Section from "@components/ui/Section.astro";
import type { ContactInfo, SectionEmbed } from "@lib/sanity/types";

interface Props {
  section: SectionEmbed;
  contactInfo: ContactInfo | null;
}

const { section, contactInfo } = Astro.props;
const height = section.height ?? 720;

/** Convertit une URL YouTube en URL embed. */
function youtubeEmbedUrl(url: string): string {
  const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]+)/);
  return match ? `https://www.youtube.com/embed/${match[1]}` : url;
}

/** HelloAsso refuse l'iframe direct (X-Frame-Options). Suffixe le path d'un widget si absent. */
function helloAssoEmbedUrl(url: string): string {
  if (/\/(widget|widget-bouton|widget-don|iframe)(\b|\/|$)/.test(url)) return url;
  return url.replace(/\/+$/, "") + "/widget-bouton";
}

/** Résout l'URL HelloAsso depuis les coordonnées centralisées ou un override. */
function resolveHelloAssoUrl(): string | undefined {
  const link = section.helloAssoLink ?? "custom";
  if (link === "adhesion") return contactInfo?.helloAssoAdhesionUrl;
  if (link === "don") return contactInfo?.helloAssoDonUrl;
  if (link === "reservation") return contactInfo?.helloAssoReservationUrl;
  return section.url;
}

const rawUrl =
  section.provider === "helloasso" ? resolveHelloAssoUrl() : section.url;

const embedUrl = !rawUrl
  ? null
  : section.provider === "youtube"
    ? youtubeEmbedUrl(rawUrl)
    : section.provider === "helloasso"
      ? helloAssoEmbedUrl(rawUrl)
      : rawUrl;

const isHelloBouton = !!embedUrl && section.provider === "helloasso" && /widget-bouton/.test(embedUrl);
const aspect = section.provider === "youtube" ? "aspect-video" : "";
const isYoutube = section.provider === "youtube";

const wrapperClass = isHelloBouton ? "mx-auto max-w-md" : "mx-auto max-w-4xl";
const innerStyle = isYoutube ? "" : isHelloBouton ? "height:110px" : `height:${height}px`;
const innerClass = isHelloBouton
  ? "overflow-hidden rounded-xl"
  : isYoutube
    ? `overflow-hidden rounded-lg ${aspect}`
    : "overflow-hidden rounded-lg";
---

<Section background="white" width="wide" spacing={isHelloBouton ? "sm" : "md"}>
  {
    section.title && (
      <h2 class="mb-4 text-center text-2xl font-semibold sm:text-3xl">{section.title}</h2>
    )
  }
  {
    embedUrl ? (
      <div class={wrapperClass}>
        <div class={innerClass} style={innerStyle}>
          <iframe
            src={embedUrl}
            title={section.title ?? `Intégration ${section.provider}`}
            class="h-full w-full"
            loading="lazy"
            sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox"
            allow={
              isYoutube
                ? "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                : undefined
            }
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          />
        </div>
      </div>
    ) : (
      <p class="text-ink-muted text-center text-sm">
        (URL d'intégration manquante — vérifier la configuration côté Studio.)
      </p>
    )
  }
</Section>
