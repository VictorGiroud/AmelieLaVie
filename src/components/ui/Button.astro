---
import type { CtaLink } from "@lib/sanity/types";

interface Props {
  cta?: CtaLink | null;
  href?: string;
  label?: string;
  external?: boolean;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  class?: string;
}

const {
  cta,
  href: hrefProp,
  label: labelProp,
  external: externalProp,
  variant: variantProp = "primary",
  size = "md",
  class: className = "",
} = Astro.props;

const href = cta?.href ?? hrefProp ?? "#";
const label = cta?.label ?? labelProp ?? "";
const external = cta?.external ?? externalProp ?? /^https?:\/\//.test(href);
const variant = cta?.variant ?? variantProp;

const base =
  "inline-flex items-center justify-center gap-2 rounded-md font-semibold transition-colors focus-visible:outline-none";
const sizing = size === "lg" ? "px-6 py-3 text-base" : "px-4 py-2 text-sm";
const variantClass =
  variant === "primary"
    ? "bg-brand-600 text-paper hover:bg-brand-700"
    : variant === "secondary"
      ? "border border-brand-600 text-brand-700 hover:bg-brand-50"
      : "text-brand-700 hover:text-brand-900";

const targetAttr = external ? "_blank" : undefined;
const relAttr = external ? "noopener noreferrer" : undefined;
---

<a
  href={href}
  class={`${base} ${sizing} ${variantClass} ${className}`}
  target={targetAttr}
  rel={relAttr}
>
  {label}
  {
    external && (
      <>
        <span aria-hidden="true" class="text-xs">
          ↗
        </span>
        <span class="sr-only"> (ouvre dans un nouvel onglet)</span>
      </>
    )
  }
</a>
