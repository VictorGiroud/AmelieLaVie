---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/ui/Container.astro";
import SanityImage from "@components/ui/Image.astro";
import PortableText from "@components/PortableText.astro";
import { getActualiteBySlug, getAllActualitesSlugs, getSiteSettings } from "@lib/sanity/queries";
import { articleJsonLd } from "@lib/seo/jsonld";

export async function getStaticPaths() {
  const slugs = await getAllActualitesSlugs();
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404/");

const [article, siteSettings] = await Promise.all([getActualiteBySlug(slug), getSiteSettings()]);
if (!article) return Astro.redirect("/404/");

const fmt = new Intl.DateTimeFormat("fr-FR", { dateStyle: "long" });

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? "https://amelielavie.org";
const canonicalUrl = new URL(`/actualites/${article.slug.current}/`, siteUrl).toString();
const jsonLd = articleJsonLd({ article, siteSettings, siteUrl, canonicalUrl });
---

<PageLayout
  title={article.title}
  description={article.description}
  seo={article.seo}
  canonicalPath={`/actualites/${article.slug.current}/`}
  jsonLd={jsonLd}
>
  <article>
    <Container width="prose" class="pt-14 sm:pt-20">
      <header>
        <p class="text-brand-700 text-sm font-medium tracking-widest uppercase">Actualité</p>
        <h1 class="mt-3 text-4xl font-semibold sm:text-5xl">{article.title}</h1>
        <p class="text-ink-muted mt-4 text-lg">{article.description}</p>
        <div class="text-ink-muted mt-6 flex flex-wrap items-center gap-4 text-sm">
          <time datetime={article.publishedAt}>{fmt.format(new Date(article.publishedAt))}</time>
          {
            article.tags && article.tags.length > 0 && (
              <ul class="flex flex-wrap gap-2">
                {article.tags.map((t) => (
                  <li class="bg-paper-alt rounded px-2 py-0.5 text-xs">#{t.title}</li>
                ))}
              </ul>
            )
          }
        </div>
      </header>
    </Container>

    {
      article.featuredImage?.asset && (
        <Container width="wide" class="mt-10">
          <SanityImage
            image={article.featuredImage}
            width={1600}
            sizes="(min-width: 1024px) 1024px, 100vw"
            loading="eager"
            class="aspect-video w-full rounded-lg object-cover"
          />
        </Container>
      )
    }

    <Container width="prose" class="py-10 sm:py-14">
      <PortableText value={article.body} class="space-y-4 leading-relaxed" />
    </Container>
  </article>
</PageLayout>
