---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/ui/Container.astro";
import SanityImage from "@components/ui/Image.astro";
import { getActualites, getAllTags, getTagBySlug } from "@lib/sanity/queries";

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map((t) => ({ params: { tag: t.slug.current } }));
}

const { tag: slug } = Astro.params;
if (!slug) return Astro.redirect("/404/");

const tag = await getTagBySlug(slug);
if (!tag) return Astro.redirect("/404/");

const articles = await getActualites(100, slug);
const fmt = new Intl.DateTimeFormat("fr-FR", { dateStyle: "long" });
---

<PageLayout
  title={`Tag : ${tag.title}`}
  description={tag.description}
  canonicalPath={`/tags/${tag.slug.current}/`}
>
  <Container width="wide" class="py-14 sm:py-20">
    <header class="mb-10 max-w-2xl">
      <p class="text-brand-700 text-sm font-medium tracking-widest uppercase">Tag</p>
      <h1 class="mt-2 text-4xl font-semibold sm:text-5xl">#{tag.title}</h1>
      {tag.description && <p class="text-ink-muted mt-4 text-lg">{tag.description}</p>}
      <p class="text-ink-muted mt-3 text-sm">
        {articles.length} article{articles.length > 1 ? "s" : ""}
      </p>
    </header>

    <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        articles.map((a) => (
          <li>
            <article class="border-border bg-paper h-full overflow-hidden rounded-lg border">
              <a href={`/actualites/${a.slug.current}/`}>
                {a.featuredImage?.asset && (
                  <SanityImage
                    image={a.featuredImage}
                    width={600}
                    sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                    class="aspect-video w-full object-cover"
                  />
                )}
                <div class="p-5">
                  <time
                    datetime={a.publishedAt}
                    class="text-ink-muted text-xs tracking-wider uppercase"
                  >
                    {fmt.format(new Date(a.publishedAt))}
                  </time>
                  <h2 class="text-brand-700 mt-2 text-lg font-semibold">{a.title}</h2>
                  <p class="text-ink-muted mt-2 line-clamp-3 text-sm">{a.description}</p>
                </div>
              </a>
            </article>
          </li>
        ))
      }
    </ul>
  </Container>
</PageLayout>
