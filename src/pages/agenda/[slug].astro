---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/ui/Container.astro";
import SanityImage from "@components/ui/Image.astro";
import PortableText from "@components/PortableText.astro";
import { getAllEvenementsSlugs, getEvenementBySlug, getSiteSettings } from "@lib/sanity/queries";
import { eventJsonLd } from "@lib/seo/jsonld";

export async function getStaticPaths() {
  const slugs = await getAllEvenementsSlugs();
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404/");

const [event, siteSettings] = await Promise.all([getEvenementBySlug(slug), getSiteSettings()]);
if (!event) return Astro.redirect("/404/");

const fmt = new Intl.DateTimeFormat("fr-FR", {
  dateStyle: "full",
  timeStyle: "short",
});
const isPast = new Date(event.startDate) < new Date();

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? "https://amelielavie.com";
const canonicalUrl = new URL(`/agenda/${event.slug.current}/`, siteUrl).toString();
const jsonLd = eventJsonLd({ event, siteSettings, canonicalUrl });
---

<PageLayout
  title={event.title}
  description={event.resume}
  seo={event.seo}
  canonicalPath={`/agenda/${event.slug.current}/`}
  jsonLd={jsonLd}
>
  <article>
    <Container width="prose" class="pt-8 sm:pt-12">
      <a
        href="/agenda/"
        class="text-ink-muted hover:text-brand-700 inline-flex items-center gap-1 text-sm font-medium transition-colors"
      >
        <span aria-hidden="true">←</span> Tout l'agenda
      </a>
      <header class="mt-6">
        <p
          class={`inline-flex rounded-full px-3 py-1 text-xs font-medium uppercase tracking-wider ${
            isPast ? "bg-paper-alt text-ink-muted" : "bg-brand-100 text-brand-800"
          }`}
        >
          {isPast ? "Événement passé" : "À venir"}
        </p>
        <h1 class="mt-3 text-3xl font-semibold sm:text-4xl">{event.title}</h1>
        <dl class="text-ink-muted mt-5 grid gap-2 text-sm sm:grid-cols-[auto_1fr] sm:gap-x-3">
          <dt class="font-medium">Date</dt>
          <dd>
            <time datetime={event.startDate}>{fmt.format(new Date(event.startDate))}</time>
            {
              event.endDate && (
                <>
                  {" — "}
                  <time datetime={event.endDate}>{fmt.format(new Date(event.endDate))}</time>
                </>
              )
            }
          </dd>
          {
            event.address && (
              <>
                <dt class="font-medium">Lieu</dt>
                <dd>
                  <a
                    href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(event.address)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-brand-700 hover:underline"
                  >
                    {event.address}
                    <span class="sr-only"> (ouvre Google Maps dans un nouvel onglet)</span>
                  </a>
                </dd>
              </>
            )
          }
        </dl>
        {event.resume && <p class="text-ink-muted mt-5 text-lg leading-relaxed">{event.resume}</p>}
      </header>
    </Container>

    {
      event.image?.asset && (
        <Container width="wide" class="mt-8">
          <SanityImage
            image={event.image}
            width={1600}
            sizes="(min-width: 1024px) 1024px, 100vw"
            loading="eager"
            class="aspect-video w-full rounded-lg object-cover"
          />
        </Container>
      )
    }

    {
      event.body && event.body.length > 0 && (
        <Container width="prose" class="py-8 sm:py-12">
          <PortableText value={event.body} class="space-y-4 leading-relaxed" />
        </Container>
      )
    }

    <Container width="prose" class="border-border mb-12 border-t pt-8">
      <a href="/agenda/" class="text-brand-700 hover:text-brand-900 text-sm font-medium">
        ← Tout l'agenda
      </a>
    </Container>
  </article>
</PageLayout>
