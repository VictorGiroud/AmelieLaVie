# Normalise les line endings : texte = LF dans le repo, le checkout local
# adapte selon le système (CRLF sur Windows). Évite les diffs et fails CI
# Prettier `endOfLine: "lf"` sur les machines Windows.
* text=auto eol=lf

# Binaires : pas de normalisation
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.svg binary
*.webp binary
*.avif binary
*.gpx binary
*.woff binary
*.woff2 binary
